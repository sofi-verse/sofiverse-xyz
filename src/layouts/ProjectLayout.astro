---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title:         string;
  description:   string;
  tags:          string[];
  meta:          Array<{ label: string; value: string }>;
  heroImage:     string;
  images:        string[];
  linkLabel:     string;
  linkHref:      string;
  imageColumns?: 1 | 2;
}

const { title, description, tags, meta, heroImage, images, linkLabel, linkHref, imageColumns = 1 } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- ── Header ── -->
  <div class="container">
    <a href="/projects" class="back-link">← go back to home</a>

    <div class="project-header">
      <div class="project-header__top">
        <h1 class="project-title">{title}</h1>
        <div class="project-tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
      </div>

      <p class="project-desc">{description}</p>

      <dl class="project-meta">
        {meta.map(({ label, value }) => (
          <div class="project-meta__item">
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- ── Hero image — full viewport width ── -->
  <div class="fullbleed">
    <img src={heroImage} alt={`${title} — overview`} />
  </div>

  <!-- ── Case study content (per-project) ── -->
  <div class="container content-sections">
    <slot />
  </div>

  <!-- ── Secondary images ── -->
  <div class:list={['container', 'project-images', { 'project-images--2col': imageColumns === 2 }]}>
    {images.map((src, i) => (
      <img src={src} alt={`${title} — ${i + 2}`} loading="lazy" class="project-image" />
    ))}
  </div>

  <!-- ── External link ── -->
  <div class="container">
    <a href={linkHref} target="_blank" rel="noopener noreferrer" class="ext-link">
      {linkLabel} →
    </a>
  </div>

  <!-- ── CTA ── -->
  <section class="project-cta">
    <div class="container">
      <p class="project-cta__label">Working on something similar? →</p>
      <a href="mailto:vcsofi.web3@gmail.com" class="project-cta__email">
        vcsofi.web3@gmail.com
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: var(--space-8);
  }

  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-link);
    color: var(--color-text-ghost);
    text-decoration: none;
    padding-top: var(--space-8);
    margin-bottom: var(--space-8);
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--color-text-primary); }

  /* ── Header ── */
  .project-header { padding-bottom: var(--space-8); }

  .project-header__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--color-text-primary);
  }

  .project-tags {
    display: flex;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .project-desc {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.1;
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  /* ── Meta row ── */
  .project-meta {
    display: flex;
    gap: var(--space-12);
    margin: 0;
    flex-wrap: wrap;
  }

  .project-meta__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-meta__item dt {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-ghost);
  }

  .project-meta__item dd {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* ── Full-bleed hero ── */
  .fullbleed { width: 100%; }

  .fullbleed img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Content sections wrapper ── */
  .content-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  /* ── Secondary images ── */
  .project-images {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-top: var(--space-8);
    padding-bottom: 0;
  }

  .project-images--2col {
    grid-template-columns: 1fr 1fr;
  }

  .project-image {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .project-images--2col {
      grid-template-columns: 1fr;
    }
  }

  /* ── External link ── */
  .ext-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-link);
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    padding-top: 12px;
    padding-bottom: var(--space-8);
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .ext-link:hover {
    color: var(--color-text-primary);
    text-decoration-color: var(--color-text-primary);
  }

  /* ── CTA ── */
  .project-cta { padding-block: var(--space-24); }

  .project-cta__label {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
    line-height: 1.1;
  }

  .project-cta__email {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, var(--text-h1));
    font-weight: 400;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1;
    display: inline-block;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .project-cta__email:hover { border-bottom-color: var(--color-text-primary); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .project-header__top { flex-direction: column; }
    .project-meta { gap: var(--space-8); }
  }
</style>
