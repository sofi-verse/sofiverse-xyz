---
import BaseLayout from '../layouts/BaseLayout.astro';

const logos = [
  { src: '/logo-blossom.svg',     alt: 'Blossom'            },
  { src: '/logo-ethmx.svg',       alt: 'Ethereum Mexico'    },
  { src: '/logo-superfluid.svg',  alt: 'Superfluid'         },
  { src: '/logo-perkos.svg',      alt: 'PerkOS'             },
  { src: '/logo-gpdevguild.svg',  alt: 'Greenpill Dev Guild'},
  { src: '/logo-edge.svg',        alt: 'Edge'               },
  { src: '/logo-frutero.svg',     alt: 'Frutero'            },
  { src: '/logo-gardens.svg',     alt: 'Gardens'            },
  { src: '/logo-tamul.svg',       alt: 'Tamul Security'     },
];

const projects = [
  {
    image:       '/img-edge-01.jpg',
    tags:        ['content', 'design'],
    year:        '2026',
    title:       'Edge Network',
    description: 'Brand, content, and community design for Edge Network, a decentralised cloud infrastructure project: graphic design and visual identity, community campaigns, branded merchandise, and a weekly Discord recap built to keep community engaged and aligned on direction and progress.',
    href:        '/projects/edge',
  },
  {
    image:       '/img-swarm-01.jpg',
    tags:        ['product'],
    year:        '2026',
    title:       'Swarm',
    description: 'Full product redesign of Swarm, PerkOS\'s real-time communication, task boards, and agent management for organizations app. A desktop experience rebuilt for clarity and decision speed, the first native mobile version, plus a logo proposal aligned with the product\'s next chapter.',
    href:        '/projects/swarm',
  },
  {
    image:       '/img-gpdg-01.jpg',
    tags:        ['design'],
    year:        '2025',
    title:       'Regenerative Stack',
    description: 'Infographics series explaining the Greenpill Dev Guild\'s work, products, and ecosystem impact across the regenerative ecosystem.',
    href:        '/projects/regenerative-stack',
  },
];
---

<BaseLayout title="Home">

  <!-- ── Hero ────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__grid-bg" aria-hidden="true"></div>
    <div class="container">
      <h1 class="hero__heading">
        I turn <em>complex<br />tech</em> into clear<br />product.
      </h1>
      <p class="hero__sub">
        Product design (UX) and visual content for technical tools. I ramp fast
        on any domain and make it clear: in the app and in how it's explained.
      </p>
    </div>
  </section>

  <!-- ── Logos ────────────────────────────────────── -->
  <section class="logos" aria-label="Teams I've worked with">
    <div class="logos__inner container">
      <span class="logos__label">Teams I've<br />worked with</span>
      <ul class="logos__list" role="list">
        {logos.map(({ src, alt }) => (
          <li class="logos__item">
            <img src={src} alt={alt} class="logos__img" loading="lazy" />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────── -->
  <section class="work">
    <div class="container">
      <div class="work__header">
        <h2 class="type-h3">Selected Work</h2>
        <a href="/projects" class="work__see-all">see all projects →</a>
      </div>

      <ul class="work__list" role="list">
        {projects.map(({ image, tags, year, title, description, href }) => (
          <li class="project-card">
            <div class="project-card__image">
              <img src={image} alt={title} loading="lazy" />
            </div>
            <div class="project-card__content">
              <div class="project-card__meta">
                <div class="project-card__tags">
                  {tags.map(t => <span class="tag">{t}</span>)}
                </div>
                <span class="project-card__year">{year}</span>
              </div>
              <h3 class="project-card__title">{title}</h3>
              <p class="project-card__desc">{description}</p>
              <a href={href} class="project-card__link">view full project →</a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────── -->
  <section class="cta">
    <div class="container">
      <h2 class="cta__heading">
        Your product is powerful.<br />The problem is it's hard<br />to understand.
      </h2>
      <div class="cta__body">
        <p>That's my whole job. I work with technical teams on the design and content that makes their products legible.</p>
        <p>Drop me a line and tell me what you're building.</p>
      </div>
      <a href="mailto:vcsofi.web3@gmail.com" class="cta__email">vcsofi.web3@gmail.com</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared container ── */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: var(--space-8);
  }

  /* ───────────────────────────────────────────── */
  /* Hero                                          */
  /* ───────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-24);
    overflow: hidden;
  }

  .hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image: url('/bg-grid.png');
    background-repeat: repeat;
    background-size: auto;
    background-position: top right;
    /* fade out to the left so text stays readable */
    mask-image: linear-gradient(to left, rgba(0,0,0,0.25) 0%, transparent 65%);
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0.25) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero .container {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero__heading {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin-bottom: var(--space-8);
  }

  .hero__heading em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-ghost);
  }

  .hero__sub {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 46ch;
  }

  /* ───────────────────────────────────────────── */
  /* Logos                                         */
  /* ───────────────────────────────────────────── */
  .logos {
    border-block: var(--border-subtle);
  }

  .logos__inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-6);
  }

  .logos__label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-ghost);
    line-height: 1.4;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logos__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .logos__img {
    height: 18px;
    width: auto;
    max-width: 100px;
    opacity: 0.65;
    filter: grayscale(1) brightness(1.4);
    object-fit: contain;
    transition: opacity 0.2s;
  }

  .logos__img:hover {
    opacity: 1;
  }

  /* ───────────────────────────────────────────── */
  /* Selected Work                                 */
  /* ───────────────────────────────────────────── */
  .work {
    padding-block: var(--space-16);
  }

  .work__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-12);
  }

  .work__see-all {
    font-family: var(--font-sans);
    font-size: var(--text-link);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .work__see-all:hover {
    color: var(--color-text-primary);
  }

  .work__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Project card ── */
  .project-card {
    display: grid;
    grid-template-columns: 55fr 45fr;
    border-top: var(--border-subtle);
  }

  .project-card:last-child {
    border-bottom: var(--border-subtle);
  }

  .project-card__image {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-card__image img {
    transform: scale(1.02);
  }

  .project-card__content {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-left: var(--border-subtle);
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .project-card__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .project-card__year {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-ghost);
    white-space: nowrap;
    margin-left: auto;
  }

  .project-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-h2);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .project-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .project-card__link {
    font-family: var(--font-sans);
    font-size: var(--text-link);
    color: var(--color-text-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    align-self: flex-start;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 0.2s;
  }

  .project-card__link:hover {
    border-bottom-color: var(--color-text-primary);
  }

  /* ───────────────────────────────────────────── */
  /* CTA                                           */
  /* ───────────────────────────────────────────── */
  .cta {
    padding-block: var(--space-24);
    border-top: var(--border-subtle);
  }

  .cta__heading {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin-bottom: var(--space-8);
    max-width: 18ch;
  }

  .cta__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    max-width: 48ch;
  }

  .cta__body p {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .cta__email {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text-ghost);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .cta__email:hover {
    border-bottom-color: var(--color-text-primary);
  }

  /* ───────────────────────────────────────────── */
  /* Responsive                                    */
  /* ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero__heading {
      font-size: clamp(2.5rem, 8vw, var(--text-h1));
    }

    .cta__heading {
      font-size: clamp(2rem, 7vw, var(--text-h1));
    }

    .project-card {
      grid-template-columns: 1fr;
    }

    .project-card__image {
      aspect-ratio: 16 / 9;
    }

    .project-card__content {
      border-left: none;
      border-top: var(--border-subtle);
    }

    .project-card__title {
      font-size: var(--text-h3);
    }
  }

  @media (max-width: 600px) {
    .logos__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .logos__list {
      gap: var(--space-6);
    }

    .work__header {
      flex-direction: column;
      gap: var(--space-2);
    }

    .cta__heading {
      max-width: none;
    }
  }
</style>
