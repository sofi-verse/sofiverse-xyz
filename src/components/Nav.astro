---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/about',  label: 'about me'    },
  { href: '/projects', label: 'projects'    },
  { href: '/how-we-work',  label: 'how we work' },
];
---

<header class="nav-wrapper">
  <nav class="nav" id="nav">
    <a href="/" class="nav__logo" aria-label="sofiverse home">
      <img src="/logo-sofiverse.svg" alt="sofiverse" width="79" height="16" />
    </a>

    <ul class="nav__links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[{ 'nav__link--active': currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav__end">
      <a href="https://t.me/sofiverse" target="_blank" rel="noopener noreferrer" class="btn">contact</a>
      <button
        class="nav__hamburger"
        id="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div class="nav__drawer" id="nav-drawer" aria-hidden="true">
    <ul role="list">
      {links.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
      <li><a href="https://t.me/sofiverse" target="_blank" rel="noopener noreferrer" class="btn nav__drawer-btn">contact</a></li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const drawer = document.getElementById('nav-drawer')!;
  const header = toggle.closest('.nav-wrapper')!;

  toggle.addEventListener('click', () => {
    const open = header.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
    drawer.setAttribute('aria-hidden', String(!open));
  });

  // Close drawer when a link inside it is clicked
  drawer.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      header.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<style>
  .nav-wrapper {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg-primary);
    border-bottom: var(--border-subtle);
  }

  /* ── Desktop bar ── */
  .nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 60px;
    padding: 0 var(--space-8);
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    justify-self: start;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo img {
    display: block;
    height: 16px;
    width: auto;
  }

  .nav__links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__links a {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .nav__links a:hover,
  .nav__links :global(.nav__link--active) {
    border-bottom-color: var(--color-text-primary);
  }

  .nav__end {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    justify-self: end;
  }

  /* ── Hamburger ── */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav__hamburger span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transition: transform 0.2s, opacity 0.2s;
    transform-origin: center;
  }

  /* Hamburger → X animation */
  .is-open .nav__hamburger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .is-open .nav__hamburger span:nth-child(2) {
    opacity: 0;
  }
  .is-open .nav__hamburger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Mobile drawer ── */
  .nav__drawer {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.25s ease;
    border-top: var(--border-subtle);
  }

  .nav__drawer ul {
    list-style: none;
    margin: 0;
    padding: var(--space-6) var(--space-8) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .nav__drawer a {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .nav__drawer-btn {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .nav__links {
      display: none;
    }

    .nav__end {
      grid-column: 3;
    }

    .nav__end .btn {
      display: none;
    }

    .nav__hamburger {
      display: flex;
    }

    .nav__drawer {
      display: block;
    }

    .is-open .nav__drawer {
      max-height: 400px;
    }
  }
</style>
